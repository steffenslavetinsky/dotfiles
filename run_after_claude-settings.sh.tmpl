{{ if lookPath "jq" -}}
#!/usr/bin/env bash
set -euo pipefail

SETTINGS="$HOME/.claude/settings.json"
mkdir -p "$HOME/.claude"

{{ if lookPath "rtk" -}}
RTK_HOOK_CMD='rtk hook claude'
{{ else -}}
RTK_HOOK_CMD='command -v rtk >/dev/null 2>&1 && rtk hook claude || true'
{{ end -}}

