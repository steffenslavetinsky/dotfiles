# Initialize terminal theming for the current directory
# Usage: terminal_theme_init [#hex_color]
#   Without args: generates a random light pastel
#   With arg:     uses the given color as the background base
#
# Creates .envrc, generates a claude variant, and registers both themes.
function terminal_theme_init() {
  local base_color="$1"
  local name="${PWD:t}"  # directory basename as theme name
  local themes_file="$DOTFILES_ROOT/zsh/terminal-themes.conf"
  local fg="#2e3440"

  # Generate random light pastel if no color given
  if [[ -z "$base_color" ]]; then
    local r=$((RANDOM % 30 + 210))
    local g=$((RANDOM % 30 + 210))
    local b=$((RANDOM % 30 + 210))
    # Bias one channel up for a noticeable tint
    case $((RANDOM % 3)) in
      0) r=$(( r + 20 > 250 ? 250 : r + 20 )) ;;
      1) g=$(( g + 20 > 250 ? 250 : g + 20 )) ;;
      2) b=$(( b + 20 > 250 ? 250 : b + 20 )) ;;
    esac
    base_color=$(printf "#%02x%02x%02x" $r $g $b)
  fi

  # Strip # prefix for math, then re-add
  local hex="${base_color#\#}"
  local br=$((16#${hex[1,2]}))
  local bg=$((16#${hex[3,4]}))
  local bb=$((16#${hex[5,6]}))

  # Generate claude variant: darken by 20% and saturate toward the dominant channel
  local cr=$(( br * 80 / 100 ))
  local cg=$(( bg * 80 / 100 ))
  local cb=$(( bb * 80 / 100 ))
  local claude_bg=$(printf "#%02x%02x%02x" $cr $cg $cb)

  # Claude foreground: darken further for contrast
  local fr=$(( br * 30 / 100 ))
  local fgr=$(( bg * 30 / 100 ))
  local fb=$(( bb * 30 / 100 ))
  local claude_fg=$(printf "#%02x%02x%02x" $fr $fgr $fb)

  # Check if theme already exists
  if grep -q "^${name} " "$themes_file" 2>/dev/null; then
    echo "Theme '$name' already exists."
    read -q "reply?Overwrite? [y/N] " || { echo ""; return 0; }
    echo ""
    sed -i '' "/^${name} /d;/^${name}-claude /d" "$themes_file"
  fi

  # Append themes
  echo "${name} ${base_color} ${fg}" >> "$themes_file"
  echo "${name}-claude ${claude_bg} ${claude_fg}" >> "$themes_file"

  # Register in current session
  TERMINAL_THEMES[$name]="${base_color} ${fg}"
  TERMINAL_THEMES[${name}-claude]="${claude_bg} ${claude_fg}"

  # Create or update .envrc
  if [[ -f .envrc ]]; then
    if grep -q "TERMINAL_THEME" .envrc; then
      local existing
      existing=$(grep "TERMINAL_THEME" .envrc | head -1)
      echo "Existing .envrc has: $existing"
      read -q "reply?Replace with TERMINAL_THEME=\"${name}\"? [y/N] " || { echo ""; echo "Skipped .envrc update."; direnv allow .; return 0; }
      echo ""
      sed -i '' "s/^export TERMINAL_THEME=.*/export TERMINAL_THEME=\"${name}\"/" .envrc
      echo "Updated TERMINAL_THEME in .envrc"
    else
      echo "export TERMINAL_THEME=\"${name}\"" >> .envrc
      echo "Added TERMINAL_THEME to existing .envrc"
    fi
  else
    echo "export TERMINAL_THEME=\"${name}\"" > .envrc
    echo "Created .envrc"
  fi

  direnv allow .

  echo ""
  echo "Theme '${name}' initialized:"
  echo "  Base:   bg=${base_color} fg=${fg}"
  echo "  Claude: bg=${claude_bg} fg=${claude_fg}"
  echo ""
  echo "Applying theme now..."
  terminal_theme "$name"
}
